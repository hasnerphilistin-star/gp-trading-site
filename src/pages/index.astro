---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProductsSection from '../components/ProductsSection.astro';
import VideoCarousel from '../components/VideoCarousel.astro';
import Pricing from '../components/Pricing.astro';
import ComboPricing from '../components/ComboPricing.astro';
import Footer from '../components/Footer.astro';
import posts from '../data/published.json';

const sortedByViews = [...posts].sort((a, b) => b.views - a.views);
const mostViewed = sortedByViews[0];

const sortedByDate = [...posts].sort((a, b) => new Date(b.date) - new Date(a.date));
const latestTwo = sortedByDate.filter(p => p.slug !== mostViewed.slug).slice(0, 2);

const featured = [mostViewed, ...latestTwo];
---
<Layout>
  <Header />
  <div id="main-content">
    <Hero />
    <ProductsSection />
    <VideoCarousel />
    <Pricing />
    <ComboPricing />

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 text-xs font-mono text-accent bg-accent/10 border border-accent/20 rounded-full mb-4">
          Blog
        </span>
        <h2 class="text-2xl md:text-4xl font-bold tracking-tight">
          Últimos del <span class="gradient-text">Blog</span>
        </h2>
        <p class="text-gray-400 mt-3 max-w-xl mx-auto">
          Tutoriales, guías y análisis sobre Order Flow, SMC y las herramientas de la suite.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured.map((post) => (
          <a href={`/blog/${post.slug}`} class={`glass-card p-6 group hover:ring-1 hover:ring-accent/30 transition-all flex flex-col ${post.slug === mostViewed.slug ? 'ring-1 ring-accent/40' : ''}`}>
            {post.slug === mostViewed.slug && (
              <div class="flex items-center gap-1.5 text-xs text-accent font-semibold mb-2">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                Más popular
              </div>
            )}
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
              <span class="px-2 py-0.5 text-accent bg-accent/10 border border-accent/20 rounded-full">{post.category}</span>
              <span>{post.date}</span>
            </div>
            <h3 class="font-bold text-white group-hover:text-accent transition-colors mb-2">{post.title.split(' —')[0]}</h3>
            <p class="text-sm text-gray-400 leading-relaxed flex-1">{post.excerpt}</p>
            <span class="mt-4 text-sm font-semibold text-accent group-hover:gap-2 inline-flex items-center gap-1 transition-all">Leer artículo <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/blog" class="inline-flex items-center gap-2 px-6 py-4 text-sm font-semibold text-primary bg-accent rounded-full hover:bg-accent-400 transition-all min-h-[44px]">
          Ver todos los artículos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </section>
  </div>
  <Footer />
</Layout>
