---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada - GP Trading" description="La página que buscas no está disponible. Regresa al inicio de GP Trading.">
  <main class="min-h-screen flex items-center justify-center pt-20">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-8xl font-bold gradient-text mb-4">404</div>
      <h1 class="text-2xl md:text-3xl font-bold mb-4">Página no encontrada</h1>
      <p class="text-gray-400 mb-8">La página que buscas no existe o ha sido movida.</p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary bg-accent rounded-full hover:bg-accent-400 transition-all hover:scale-105 glow">
        Volver al inicio
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </main>
</Layout>